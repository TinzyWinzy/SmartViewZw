rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      // Anyone can submit a booking inquiry
      allow create: if request.resource.data.keys().hasAll(['clientName', 'email', 'phone', 'location', 'serviceNeeded', 'frequency']);
      // Authenticated admin can read, update status, delete
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    match /academy_applications/{applicationId} {
      // Anyone can submit an academy application
      allow create: if request.resource.data.keys().hasAll(['applicantName', 'nationalId', 'phone', 'location', 'selectedCourseId']);
      // Authenticated admin can read, update status, delete
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }
  }
}
